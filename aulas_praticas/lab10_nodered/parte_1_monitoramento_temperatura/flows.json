    {
        "id": "43baf2fe6b70baa7",
        "type": "function",
        "z": "d78da4550da9bf2a",
        "name": "render_gauge",
        "func": "const useF = flow.get(\"useF\") || false;\nconst history = flow.get(\"history\") || [];\n\nconst lastTemps = history.slice(-7);\n\nif (lastTemps.length === 0) {\n    return null;\n}\n\nconst values = lastTemps.map(p => useF ? p.f : p.c);\n\nconst sum = values.reduce((acc, value) => acc + value, 0);\nconst avg = sum / values.length;\n\nmsg.payload = Number(avg.toFixed(1));\n\nmsg.ui_update = {\n    label: \"Média das últimas 7 temperaturas\",\n    units: useF ? \"°F\" : \"°C\",\n    min: useF ? 60 : 20,\n    max: useF ? 110 : 40\n};\n\nreturn msg;",
        "outputs": 1,
