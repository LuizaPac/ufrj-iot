    {
        "id": "6615b59944cbec28",
        "type": "function",
        "z": "d78da4550da9bf2a",
        "name": "render_chart",
        "func": "const useF = flow.get(\"useF\") || false;\nconst history = flow.get(\"history\") || [];\n\nconst unidade = useF ? \"°F\" : \"°C\";\nconst label = useF ? \"Temperatura em Fahrenheit\" : \"Temperatura em Celsius\";\n\nmsg.payload = history.map(p => ({\n    x: p.t,\n    y: useF ? p.f : p.c\n}));\n\nmsg.topic = label;\nmsg.action = \"replace\";\n\nmsg.ui_update = {\n    label: `Histórico de Temperatura (${unidade})`,\n    yAxisLabel: `Temperatura (${unidade})`,\n    ymin: useF ? 60 : 20,\n    ymax: useF ? 110 : 40,\n    chartOptions: {\n        tooltip: {\n            trigger: \"axis\",\n            valueFormatter: value => `${Number(value).toFixed(1)} ${unidade}`\n        }\n    }\n};\n\nreturn msg;",
        "outputs": 1,
