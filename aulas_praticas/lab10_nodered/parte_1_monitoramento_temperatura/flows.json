    {
        "id": "90a03ff49a5c2467",
        "type": "function",
        "z": "d78da4550da9bf2a",
        "name": "mocked_humid",
        "func": "const now = Date.now();\nconst lastHumidityTime = flow.get(\"last_humidity_time\") || 0;\n\nconst timeout = 3000;\n\nif (now - lastHumidityTime < timeout) {\n    return null;\n}\n\nconst t = now / 1000;\nconst periodo = 10;\n\n// Mock de umidade absoluta em kg/m3.\n// Valor típico aproximado em ar ambiente: algo entre 0.005 e 0.025 kg/m3.\nconst humidityKgM3 = 0.014 + 0.004 * Math.sin(2 * Math.PI * t / periodo);\n\n// Mock de umidade relativa, independente, apenas para teste visual.\nconst relativeHumidity = 60 + 20 * Math.sin(2 * Math.PI * t / periodo);\n\nmsg.payload = humidityKgM3;\nmsg.relativeHumidity = relativeHumidity;\nmsg.topic = \"umidade\";\nmsg.source = \"mock\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
