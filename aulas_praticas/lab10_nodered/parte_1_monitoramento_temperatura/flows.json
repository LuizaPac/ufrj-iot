    {
        "id": "4b27a55823dc5fd4",
        "type": "function",
        "z": "d78da4550da9bf2a",
        "name": "render_gauge",
        "func": "const unit = flow.get(\"humidityUnit\") || \"kgm3\";\n\nlet humidity = msg.humidity;\n\nif (!humidity) {\n    humidity = flow.get(\"last_humidity_values\");\n}\n\nif (!humidity) {\n    return null;\n}\n\nflow.set(\"last_humidity_values\", humidity);\n\nif (unit === \"lbft3\") {\n    msg.payload = Number(humidity.lbft3.toFixed(5));\n\n    msg.ui_update = {\n        label: \"Umidade absoluta\",\n        units: \"lb/ft³\",\n        min: 0,\n        max: 0.002\n    };\n\n    return msg;\n}\n\nif (unit === \"relative\") {\n    if (humidity.relative === undefined) {\n        return null;\n    }\n\n    msg.payload = Number(humidity.relative.toFixed(1));\n\n    msg.ui_update = {\n        label: \"Umidade relativa\",\n        units: \"%\",\n        min: 0,\n        max: 100\n    };\n\n    return msg;\n}\n\nmsg.payload = Number(humidity.kgm3.toFixed(4));\n\nmsg.ui_update = {\n    label: \"Umidade absoluta\",\n    units: \"kg/m³\",\n    min: 0,\n    max: 0.03\n};\n\nreturn msg;",
