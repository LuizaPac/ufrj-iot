    {
        "id": "454def5908709b47",
        "type": "function",
        "z": "d78da4550da9bf2a",
        "name": "mocked_temp",
        "func": "const now = Date.now();\nconst lastMqttTime = flow.get(\"last_mqtt_time\") || 0;\n\nconst timeout = 10000; // 3 segundos sem MQTT = usar mock\n\nif (now - lastMqttTime < timeout) {\n    return null;\n}\n\nconst t = now / 1000;\nconst periodo = 10;\n\nconst temperatura = 28 + 3 * Math.sin(2 * Math.PI * t / periodo);\n\nmsg.payload = temperatura;\nmsg.topic = \"temperatura\";\nmsg.source = \"mock\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 700,
        "y": 520,
